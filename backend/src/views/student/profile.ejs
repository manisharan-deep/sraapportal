<%- include('../partials/header') %>
<h3>Profile</h3>
<div class="card mb-3"><div class="card-body">
  <p><strong>Name:</strong> <%= student.userId.fullName %></p>
  <p><strong>Email:</strong> <%= student.userId.email %></p>
  <p><strong>Branch:</strong> <%= student.branch %></p>
  <p><strong>Section:</strong> <%= student.section %></p>
  <p><strong>Semester:</strong> <%= student.semester %></p>
  <p><strong>Mentor:</strong> <%= student.mentor %></p>
  <p><strong>Approval pending:</strong> <%= student.profileEditPendingApproval %></p>
  <form method="post" action="/student/profile/request-update" class="row g-2 mt-2">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <div class="col-md-3"><input class="form-control" name="branch" value="<%= student.pendingProfileData?.branch || student.branch %>" required></div>
    <div class="col-md-2"><input class="form-control" name="section" value="<%= student.pendingProfileData?.section || student.section %>" required></div>
    <div class="col-md-2"><input class="form-control" name="semester" type="number" min="1" max="12" value="<%= student.pendingProfileData?.semester || student.semester %>" required></div>
    <div class="col-md-3"><input class="form-control" name="mentor" value="<%= student.pendingProfileData?.mentor || student.mentor %>" required></div>
    <div class="col-md-2"><button class="btn btn-warning w-100">Request Approval</button></div>
  </form>
</div></div>
<%- include('../partials/footer') %>
